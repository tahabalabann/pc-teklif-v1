generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                 String        @id
  name               String
  logoUrl            String?
  phone              String?
  email              String?
  address            String?
  sellerInfo         String?
  paymentAccountName String?
  paymentIban        String?
  notes              String?
  isActive           Boolean       @default(true)
  createdAt          String
  users              User[]
  walletLedger       WalletLedger[]
}

model User {
  id                String               @id
  name              String
  email             String               @unique
  role              String
  createdAt         String
  passwordHash      String
  passwordSalt      String
  balance           Float          @default(0)
  companyId         String?
  company           Organization?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  isPlatformAdmin   Boolean        @default(false)
  isActive          Boolean        @default(true)
  quotes            Quote[]
  addressBook       AddressBookEntry[]
  senderAddressBook SenderAddressBookEntry[]
  companies         CompanyDirectoryEntry[]
  products          ProductCatalogEntry[]
  shipmentRecords   ShipmentRecord[]
  depositRequests   DepositRequest[]     @relation("DepositRequester")
  approvedRequests  DepositRequest[]     @relation("DepositApprover")
  notifications     Notification[]
  sessions          Session[]
  walletLedger      WalletLedger[] @relation("WalletLedgerUser")
  walletCreated     WalletLedger[] @relation("WalletLedgerCreator")
}

model Quote {
  id          String @id
  ownerUserId String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model AddressBookEntry {
  id          String @id
  ownerUserId String
  label       String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model SenderAddressBookEntry {
  id          String @id
  ownerUserId String
  label       String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model CompanyDirectoryEntry {
  id          String @id
  ownerUserId String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model ShipmentRecord {
  id          String @id
  ownerUserId String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model DepositRequest {
  id               String @id
  requesterUserId  String
  amount           Float
  note             String
  status           String
  approvedByUserId String?
  createdAt        String
  updatedAt        String
  requester        User   @relation("DepositRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  approver         User?  @relation("DepositApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
}

model Notification {
  id          String @id
  ownerUserId String
  data        String
  readAt      String?
  createdAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model Session {
  token      String @id
  userId     String
  createdAt  String
  lastSeenAt String
  expiresAt  String?
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletLedger {
  id              String        @id
  userId          String
  companyId       String
  type            String
  amount          Float
  balanceAfter    Float
  note            String
  createdAt       String
  createdByUserId String?
  data            String
  user            User          @relation("WalletLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  company         Organization  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser   User?         @relation("WalletLedgerCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String @id
  companyId   String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  message     String
  data        String
  createdAt   String
}

model ProductCatalogEntry {
  id          String @id
  ownerUserId String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}
