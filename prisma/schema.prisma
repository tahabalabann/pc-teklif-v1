generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String @id
  name      String
  logoUrl   String?
  phone     String?
  email     String?
  address   String?
  sellerInfo String?
  paymentAccountName String?
  paymentIban String?
  createdAt String
  users     User[]
}

model User {
  id                String               @id
  name              String
  email             String               @unique
  role              String
  createdAt         String
  passwordHash      String
  passwordSalt      String
  balance           Float?
  companyId         String?
  company           Organization?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  quotes            Quote[]
  addressBook       AddressBookEntry[]
  senderAddressBook SenderAddressBookEntry[]
  companies         CompanyDirectoryEntry[]
  shipmentRecords   ShipmentRecord[]
  depositRequests   DepositRequest[]     @relation("DepositRequester")
  approvedRequests  DepositRequest[]     @relation("DepositApprover")
  sessions          Session[]
}

model Quote {
  id          String @id
  ownerUserId String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model AddressBookEntry {
  id          String @id
  ownerUserId String
  label       String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model SenderAddressBookEntry {
  id          String @id
  ownerUserId String
  label       String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model CompanyDirectoryEntry {
  id          String @id
  ownerUserId String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model ShipmentRecord {
  id          String @id
  ownerUserId String
  data        String
  createdAt   String
  updatedAt   String
  user        User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model DepositRequest {
  id               String @id
  requesterUserId  String
  amount           Float
  note             String
  status           String
  approvedByUserId String?
  createdAt        String
  updatedAt        String
  requester        User   @relation("DepositRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  approver         User?  @relation("DepositApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
}

model Session {
  token      String @id
  userId     String
  createdAt  String
  lastSeenAt String
  expiresAt  String?
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
